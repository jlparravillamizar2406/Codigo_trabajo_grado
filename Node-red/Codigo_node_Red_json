        "func": "// -------------------------------------------------\n// OBTENER OD GLOBAL\n// -------------------------------------------------\nlet od = global.get(\"OD_manual\");\n\n// 🔥 INICIALIZACIÓN AUTOMÁTICA\nif (od === undefined) {\n    od = 7.66; // valor por defecto\n    global.set(\"OD_manual\", od);\n    node.warn(\"OD inicializado: \" + od);\n}\n\n// -------------------------------------------------\n// LIMPIAR OD DEL SENSOR (CRÍTICO)\n// -------------------------------------------------\ndelete msg.payload.OD;\n\n// -------------------------------------------------\n// VARIABLES\n// -------------------------------------------------\nlet experiment = global.get(\"experiment\") || \"exp1\";\nlet data = msg.payload;\n\n// -------------------------------------------------\n// FORMATO PARA INFLUX\n// -------------------------------------------------\nmsg.measurement = \"espectro_raw\";\n\nmsg.payload = {\n    experiment: experiment,\n\n    TempBMP: Number(data.TempBMP),\n    TempDS: Number(data.TempDS),\n\n    A: Number(data.A),\n    B: Number(data.B),\n    C: Number(data.C),\n    D: Number(data.D),\n    E: Number(data.E),\n    F: Number(data.F),\n    G: Number(data.G),\n    H: Number(data.H),\n\n    R: Number(data.R),\n    I: Number(data.I),\n    S: Number(data.S),\n    J: Number(data.J),\n    T: Number(data.T),\n    U: Number(data.U),\n    V: Number(data.V),\n    W: Number(data.W),\n\n    K: Number(data.K),\n    L: Number(data.L),\n\n    // 🔥 ÚNICO OD VÁLIDO\n    OD: Number(od)\n};\n\nreturn msg;",
