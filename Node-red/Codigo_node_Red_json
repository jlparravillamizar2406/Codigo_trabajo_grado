        "id": "db2881dcc65c2683",
        "type": "function",
        "z": "951e2f7cf9ec780f",
        "name": "Func Promedio",
        "func": "// -------------------------------------------------\n// BUFFER\n// -------------------------------------------------\nif (!context.buffer) {\n    context.buffer = [];\n}\n\ncontext.buffer.push(msg.payload);\n\n// -------------------------------------------------\nif (context.buffer.length === 15) {\n\n    let result = {};\n    let keys = Object.keys(context.buffer[0]);\n\n    keys.forEach(key => {\n\n        let values = context.buffer.map(sample => sample[key]);\n        values = values.filter(v => typeof v === \"number\");\n\n        if (values.length < 3) return;\n\n        values.sort((a, b) => a - b);\n        let trimmed = values.slice(1, values.length - 1);\n\n        let sum = trimmed.reduce((a, b) => a + b, 0);\n        result[key] = sum / trimmed.length;\n    });\n\n    context.buffer = [];\n\n    // -------------------------------------------------\n    // OD GLOBAL\n    // -------------------------------------------------\n    let od = global.get(\"OD_manual\");\n\n    if (od === undefined) {\n        od = 7.66;\n        global.set(\"OD_manual\", od);\n        node.warn(\"OD inicializado en promedio: \" + od);\n    }\n\n    let experiment = global.get(\"experiment\") || \"exp1\";\n\n    // -------------------------------------------------\n    // SALIDAS\n    // -------------------------------------------------\n\n    let msg_param = {\n        measurement: \"parametros_sensor\",\n        payload: {\n            Time: Number(result.time),\n            Ganancia: Number(result.gain),\n            Inttime: Number(result.intTime),\n            experiment: experiment\n        }\n    };\n\n    let msg_espectro = {\n        measurement: \"espectro_od\",\n        payload: {\n            experiment: experiment,\n\n            A: Number(result.A),\n            B: Number(result.B),\n            C: Number(result.C),\n            D: Number(result.D),\n            E: Number(result.E),\n            F: Number(result.F),\n            G: Number(result.G),\n            H: Number(result.H),\n\n            R: Number(result.R),\n            I: Number(result.I),\n            S: Number(result.S),\n            J: Number(result.J),\n            T: Number(result.T),\n            U: Number(result.U),\n            V: Number(result.V),\n            W: Number(result.W),\n\n            TempBMP: Number(result.TempBMP),\n            TempDS: Number(result.TempDS),\n\n            K: Number(result.K),\n            L: Number(result.L),\n\n            OD: Number(od)\n        }\n    };\n\n    let msg_ambiental = {\n        measurement: \"ambiental\",\n        payload: {\n            experiment: experiment,\n            TempBMP: Number(result.TempBMP),\n            Pressure: Number(result.Pressure),\n            TempDS: Number(result.TempDS)\n        }\n    };\n\n    return [msg_param, msg_espectro, msg_ambiental];\n}\n\nreturn null;",
